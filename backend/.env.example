# ---------------------------------------------------------------------------
# FinTrust AI backend configuration.
# Copy to `.env` and edit. Every value below is OPTIONAL — the app runs with an
# empty file. You only need an LLM key to upgrade answers from "extractive"
# (offline, templated) to fluent LLM-written prose.
# ---------------------------------------------------------------------------

APP_ENV=local
LOG_LEVEL=INFO

# --- LLM (generation) ---------------------------------------------------------
# LLM_PROVIDER options: none | groq | gemini | openai | anthropic
#   none      -> no API key needed; answers are stitched from retrieved chunks.
#   groq      -> free + very fast. Get a key at https://console.groq.com
#   gemini    -> free tier. Get a key at https://aistudio.google.com/apikey
#   openai    -> https://platform.openai.com/api-keys
#   anthropic -> https://console.anthropic.com
LLM_PROVIDER=none
LLM_API_KEY=
# Leave LLM_MODEL blank to use the provider's sensible default (see llm_client.py).
LLM_MODEL=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1200

# Optional automatic fallback provider (used ONLY if the primary errors / rate-limits).
# Example: LLM_PROVIDER=groq with LLM_FALLBACK_PROVIDER=gemini.
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=

# --- Database (optional) -----------------------------------------------------
# Blank => local SQLite. For Supabase/Neon Postgres, set a full URL:
# DATABASE_URL=postgresql+psycopg://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres

# --- Auth (optional; Supabase) -----------------------------------------------
# Blank => anonymous mode (no login required). Set the project's JWT secret to
# enable per-user audit history (Supabase → Project Settings → API → JWT secret).
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Embeddings + vector store -----------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
COLLECTION_NAME=fintrust_v1
# CHROMA_PATH=./data/vector_store   # defaults under backend/data if blank

# --- Relational storage ------------------------------------------------------
# SQLITE_PATH=./data/fintrust.db    # defaults under backend/data if blank

# --- Retrieval tuning --------------------------------------------------------
RETRIEVAL_TOP_K=8
MIN_CHUNK_SCORE=0.25
REFUSAL_SCORE=0.35

# --- CORS (comma-separated) --------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
