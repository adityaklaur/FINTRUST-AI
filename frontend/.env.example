# Frontend build/runtime config. Copy to `.env` (or set in your host dashboard).

# Backend origin the browser calls in PRODUCTION (Vercel/Cloudflare build).
# Leave blank for local dev — the Vite dev server proxies /api to localhost:8000.
VITE_API_URL=

# Only needed once accounts ship (Supabase Auth). The anon key is safe to expose.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
